{
  "name": "passwall-desktop",
  "private": true,
  "version": "1.23.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode production",
    "build:update-local": "tauri build --ci --target aarch64-apple-darwin --bundles app",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:all": "pnpm test && pnpm run test:rust",
    "verify:native-manifest": "node scripts/verify-native-manifest.mjs",
    "native-host:install:prod": "node scripts/install-native-host-manifest.mjs --mode=prod",
    "native-host:install:dev": "node scripts/install-native-host-manifest.mjs --mode=dev",
    "pre-release": "node scripts/pre-release.mjs",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-http": "^2.5.8",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "i18next": "^26",
    "lucide-react": "^1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17",
    "react-router": "^7",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
