{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Passwall",
  "version": "1.17.0",
  "identifier": "io.passwall.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Passwall",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://icons.duckduckgo.com data:; connect-src 'self' https: http://localhost:* http://127.0.0.1:* http://[::1]:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCREEzQUJBM0YzMkZDRTgKUldUby9ESS91anJhcXllazNjU0hGVU5ZaEUxa1Q0NVhmQTBLbjlMM0lWVEI4SXZHemlNMHYrRzYK",
      "endpoints": [
        "https://passwall-releases.nyc3.cdn.digitaloceanspaces.com/desktop/latest.json"
      ]
    }
  }
}
